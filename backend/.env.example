# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=          # Full PEM key content (paste inline, no file path)
GITHUB_WEBHOOK_SECRET=       # Random 32-char string set when creating the app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=              # Used ONLY for embeddings

# Database
MONGODB_URI=                 # Full Atlas connection string

# Server
PORT=8000
RAILWAY_URL=                 # Set after Railway deployment (e.g. https://codesense-production.up.railway.app)
